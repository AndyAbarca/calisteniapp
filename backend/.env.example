COCKROACH_HOST=localhost
COCKROACH_PORT=26257
# Runtime identity for the app itself -- least-privilege (SELECT/INSERT/
# UPDATE/DELETE only, no DDL). See docker-compose.yml's db-init service
# for where this user and its grants get created. No password, same as
# root below -- CockroachDB's --insecure mode refuses to let a user have
# one at all.
COCKROACH_USER=app_user
COCKROACH_PASSWORD=
COCKROACH_DATABASE=crdb_calisteniaapp_db
# Admin identity, used only by Alembic and one-off scripts that need DDL
# (e.g. backend/scripts/seed_exercises.py) -- never by the app itself.
COCKROACH_ADMIN_USER=root
COCKROACH_ADMIN_PASSWORD=
